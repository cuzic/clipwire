# clipwire: Windows / Wayland / tmux クリップボードを双方向で繋ぐ
#
# ~/.tmux.conf に追記して `tmux source ~/.tmux.conf` で反映。
#
# 前提: clipwire が PATH に入っており、CLIPD_HOST 等が設定済みであること。
# Wayland 系は wl-clipboard (wl-copy / wl-paste) が必要。

# ── Windows → tmux ───────────────────────────────────────────────────────────

# <prefix> Ctrl-V: Windows クリップボード → tmux paste buffer → 現在のペインに貼り付け
#   テキスト → そのまま入力
#   画像     → /tmp/clipwire_XXX.png のパスを入力 (Claude Code がそのまま読める)
#   ファイル → curl コマンド群を入力
bind C-v run-shell "clipwire get -q | tmux load-buffer -" \; paste-buffer -p

# <prefix> Alt-V: ファイルをその場で展開 (curl コマンドを bash で実行)
#   ファイル種別のみ curl を実行してカレントディレクトリにダウンロード。
#   テキスト・画像は通常の貼り付けにフォールバック。
bind M-v run-shell " \
  kind=\$(curl -fsS --max-time 5 \
    \${CLIPD_TOKEN:+-H \"Authorization: Bearer \$CLIPD_TOKEN\"} \
    -D - -o /dev/null \
    \"http://\${CLIPD_HOST}:\${CLIPD_PORT:-9999}/clip\" 2>/dev/null \
    | tr -d '\\r' | awk -F': ' 'tolower(\$1)==\"x-clip-kind\"{print \$2}'); \
  if [ \"\$kind\" = files ] || [ \"\$kind\" = vfiles ]; then \
    clipwire get -q | bash; \
  else \
    clipwire get -q | tmux load-buffer - && tmux paste-buffer -p; \
  fi"

# ── tmux → Windows ───────────────────────────────────────────────────────────

# <prefix> Ctrl-C: tmux paste buffer → Windows クリップボード
bind C-c run-shell "tmux save-buffer - | clipwire put"

# ── Wayland ↔ Windows ────────────────────────────────────────────────────────

# <prefix> Ctrl-W: Windows クリップボード → Wayland クリップボード
bind C-w run-shell "clipwire get -q | wl-copy"

# <prefix> Alt-C: Wayland クリップボード → Windows クリップボード
bind M-c run-shell "wl-paste | clipwire put"
